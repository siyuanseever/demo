{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xiaodongwu.local/schemas/knowledge-card.schema.json",
  "title": "小动物夜谈会心理学知识卡",
  "type": "object",
  "required": [
    "id",
    "title",
    "domain",
    "card_role",
    "concept_type",
    "evidence_level",
    "risk_of_overpathologizing",
    "tags",
    "retrieval_triggers",
    "concept",
    "related_cards",
    "differential_explanations",
    "response_guidance",
    "anti_patterns",
    "evidence_caveat",
    "source",
    "source_ref"
  ],
  "properties": {
    "id": {"type": "string", "minLength": 1},
    "title": {"type": "string", "minLength": 1},
    "name_zh": {"type": "string"},
    "name_en": {"type": "string"},
    "aliases": {"type": "array", "items": {"type": "string"}},
    "domain": {"type": "string", "minLength": 1},
    "category": {"type": "array", "items": {"type": "string"}},
    "taxonomy_path": {"type": "array", "items": {"type": "string"}},
    "card_role": {
      "enum": [
        "observation",
        "mechanism",
        "differential",
        "personalized_pattern",
        "therapeutic_framework",
        "intervention"
      ]
    },
    "concept_type": {
      "enum": [
        "established_concept",
        "clinical_concept",
        "therapeutic_framework",
        "contested_theory",
        "working_concept",
        "personalized_hypothesis"
      ]
    },
    "evidence_level": {"type": "string", "minLength": 1},
    "diagnosis_required": {"type": "boolean"},
    "risk_of_overpathologizing": {"enum": ["low", "medium", "high"]},
    "tags": {"type": "array", "items": {"type": "string"}},
    "retrieval_triggers": {"type": "array", "items": {"type": "string"}},
    "concept": {"type": "string"},
    "related_cards": {"type": "array", "items": {"type": "string"}},
    "differential_explanations": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string"}
    },
    "medical_differential": {"type": "array", "items": {"type": "string"}},
    "low_load_actions": {"type": "array", "items": {"type": "string"}},
    "action_safety": {"type": "string"},
    "response_guidance": {"type": "array", "items": {"type": "string"}},
    "anti_patterns": {"type": "array", "items": {"type": "string"}},
    "evidence_caveat": {"type": "string", "minLength": 1},
    "source": {"type": "string", "minLength": 1},
    "source_ref": {"type": "string", "minLength": 1},
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["label", "url"],
        "properties": {
          "label": {"type": "string"},
          "url": {"type": "string"}
        }
      }
    }
  },
  "additionalProperties": true
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xiaodongwu.local/schemas/knowledge-response-plan.schema.json",
  "title": "心理知识检索回应计划",
  "type": "object",
  "required": [
    "extracted_state",
    "primary_cards",
    "alternative_explanations",
    "medical_differential",
    "rejected_overinterpretations",
    "response_strategy",
    "safety_flags"
  ],
  "properties": {
    "extracted_state": {
      "type": "object",
      "required": [
        "event",
        "emotion",
        "body",
        "thought",
        "urge",
        "behavior",
        "context",
        "arousal_guess",
        "uncertainty_level",
        "time_course",
        "cognitive_capacity"
      ]
    },
    "primary_cards": {"type": "array", "maxItems": 4},
    "alternative_explanations": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string"}
    },
    "medical_differential": {"type": "array", "items": {"type": "string"}},
    "rejected_overinterpretations": {"type": "array", "items": {"type": "string"}},
    "response_strategy": {"type": "array", "items": {"type": "string"}},
    "safety_flags": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": false
}
